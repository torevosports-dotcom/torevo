# Supabase — get these from your Supabase project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay — get from Razorpay Dashboard > Settings > API Keys
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key   # SERVER ONLY — never expose to client

# App config
EXPO_PUBLIC_APP_NAME=Togo
EXPO_PUBLIC_SUPPORT_EMAIL=support@togo.app
